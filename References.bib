@Article{reinikka_svensson_jpe,
  author={Reinikka, Ritva and Svensson, Jakob},
  title={{The power of information in public services: Evidence from education in Uganda}},
  journal={Journal of Public Economics},
  year=2011,
  volume={95},
  number={7-8},
  pages={956-966},
  month={August},
  keywords={ Public organizations Educational finance Economic development},
  doi={},
  abstract={In this paper we argue that innovations in governance of social services are an effective way to improve outcomes such as attainment of universal primary education. To test this hypothesis we exploit an unusual policy experiment: a newspaper campaign in Uganda aimed at reducing the capture of public funds by providing schools (parents) with systematic information to monitor local officials' handling of a large education grant program. Combining survey and administrative data, we show that public access to information can be a powerful deterrent to the capture of funds at the local level and that the reduction in the capture of funds that resulted had a positive effect on school enrollment and learning outcomes.},
  url={https://ideas.repec.org/a/eee/pubeco/v95y2011i7-8p956-966.html}
}


