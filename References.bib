}



@article{10.1086/429304,
 ISSN = {00130079, 15392988},
 URL = {http://www.jstor.org/stable/10.1086/429304},
 abstract = {Abstract Acrimonious relations between employers and employees in developing countries have often been cited as impediments to progress. This article considers various measures of labor disputes and investigates whether these have detrimental effects on the location choice of new domestic investment across the various states of India. Conventional wisdom holds that an increase in measures such as the number of strikes, the number of man‐days lost in work stoppages, and the percentage of unionized workers would hinder the location of new projects. Using panel data and a fixed‐effects methodology that controls for the effect of state‐specific unobservables, we find significant evidence that this is indeed the case in India. Furthermore, disaggregation by industrial classifications shows that, although labor disputes continue to exert negative effects, location choices are also conditioned on factors such as proximity to raw materials and minerals.},
 author = {Paroma Sanyal and Nidhiya Menon},
 journal = {Economic Development and Cultural Change},
 number = {4},
 pages = {825--854},
 publisher = {The University of Chicago Press},
 title = {Labor Disputes and the Economics of Firm Geography: A Study of Domestic Investment in India},
 volume = {53},
 year = {2005}
}



